{
  "name": "skill-lint",
  "version": "0.1.0",
  "description": "Security linter for Claude Code / agent skills. Detects prompt injection, obfuscation, credential exfiltration, and other toxic patterns before you install a skill.",
  "type": "module",
  "bin": {
    "skill-lint": "bin/skill-lint.js"
  },
  "main": "src/scanner.js",
  "exports": {
    ".": "./src/scanner.js"
  },
  "files": [
    "bin",
    "src",
    "README.md",
    "README.zh.md",
    "LICENSE"
  ],
  "scripts": {
    "test": "node --test test/*.test.js",
    "start": "node bin/skill-lint.js"
  },
  "keywords": [
    "claude-code",
    "skill",
    "security",
    "lint",
    "linter",
    "scanner",
    "prompt-injection",
    "owasp",
    "ast10",
    "agentic-ai",
    "supply-chain"
  ],
  "author": "Shen Huang <me@alwa.info> (https://github.com/ShenHuang)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/LichAmnesia/skill-lint.git"
  },
  "bugs": {
    "url": "https://github.com/LichAmnesia/skill-lint/issues"
  },
  "homepage": "https://github.com/LichAmnesia/skill-lint#readme",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "yaml": "^2.6.0"
  }
}
